# ─────────────────────────────────────────────────────────────────────────────
# Scroll2Learn — Environment Variables Template
# Copy this file to .env and fill in YOUR real values.
# ⚠️  NEVER commit the real .env file to GitHub!
# ─────────────────────────────────────────────────────────────────────────────

# ── Cloudinary (get from https://cloudinary.com → Dashboard → API Keys) ──────
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# ── Gmail SMTP (use a Google App Password, not your real password) ────────────
GMAIL_USER=your_email@gmail.com
GMAIL_PASS=your_app_password_here

# ── Gemini AI (get from https://aistudio.google.com/app/apikey) ──────────────
GEMINI_KEY=your_gemini_api_key_here

# ── Admin credentials for the built-in admin account ─────────────────────────
ADMIN_USERNAME=guru
ADMIN_PASSWORD=your_admin_password_here
